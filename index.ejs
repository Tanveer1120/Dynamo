<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= name %> | Portfolio</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<header>
    <h1><%= name %></h1>
    <p><%= role %></p>
</header>

<section class="projects">
    <h2>Projects</h2>

    <div class="project-container">
        <% projects.forEach(project => { %>
            <div class="card">
                <h3><%= project.title %></h3>
                <p><%= project.description %></p>
                <a href="<%= project.link %>">View Project</a>
            </div>
        <% }) %>
    </div>
</section>

<footer>
    <p>© 2026 <%= name %></p>
</footer>

</body>
</html>